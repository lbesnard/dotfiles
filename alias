##########################
# list of aliases with fzf
##########################
falias() {
  local tmpdir
  tmpdir=$(mktemp -d /tmp/falias.XXXXXX)

  # Store alias definitions (skip names with special chars that break filenames)
  alias | while IFS='=' read -r name def; do
    [[ "$name" =~ [^a-zA-Z0-9_.:@-] ]] && continue
    printf '%s' "${def#\'}" | sed "s/'$//" > "$tmpdir/alias_${name}"
  done

  # Store ONLY user-defined functions from ~/.alias (not zinit/plugin internals)
  local user_fns
  user_fns=$(grep -oE '^[a-zA-Z_][a-zA-Z0-9_-]*[[:space:]]*\(\)' ~/.alias 2>/dev/null \
             | sed 's/[[:space:]]*()$//')
  for fn in ${(f)user_fns}; do
    [[ -z "$fn" ]] && continue
    typeset -f "$fn" > "$tmpdir/fn_${fn}" 2>/dev/null
  done

  local selection
  selection=$(
    ls "$tmpdir" | sed 's/^alias_//;s/^fn_//' | sort -u | \
    fzf --height 60% --reverse \
        --header "Enter: run | right panel: full definition" \
        --preview "
          n={}
          if [ -f \"${tmpdir}/fn_\${n}\" ]; then
            cat \"${tmpdir}/fn_\${n}\"
          elif [ -f \"${tmpdir}/alias_\${n}\" ]; then
            echo \"alias \${n}='\$(cat ${tmpdir}/alias_\${n})'\"
          fi
        " \
        --preview-window=right:60%:wrap
  )

  rm -rf "$tmpdir"

  if [[ -n "$selection" ]]; then
    echo -e "\033[1;32mExecuting:\033[0m $selection"
    print -s "$selection"
    eval "$selection"
  fi
}

